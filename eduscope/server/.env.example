# ── MongoDB Connection ──
# For MongoDB Atlas: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
# For local MongoDB: mongodb://localhost:27017/eduscope
# IMPORTANT: If using Atlas, whitelist your IP at Atlas → Network Access → Add IP Address
MONGO_URI=mongodb://localhost:27017/eduscope

# ── Server ──
PORT=4000
JWT_SECRET=pollcast_super_secret_change_me_in_production

# ── CORS ──
# Frontend dev server URL (Vite default is 5173)
CLIENT_ORIGIN=http://localhost:5173

# ── AI Insights (Gemini) ──
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
